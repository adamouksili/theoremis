{
    "framework": "vite",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
                { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
                { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://lean.theoremis.com https://api.anthropic.com https://api.openai.com https://models.inference.ai.azure.com; worker-src 'self' blob:; frame-ancestors 'none'" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "playground.theoremis.com" }],
            "destination": "/"
        },
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "api.theoremis.com" }],
            "destination": "/"
        },
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "classroom.theoremis.com" }],
            "destination": "/"
        },
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "ide.theoremis.com" }],
            "destination": "/"
        }
    ]
}
