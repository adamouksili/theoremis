{
  "name": "theoremis",
  "version": "0.2.0",
  "type": "module",
  "description": "Hypothesis necessity linter for mathematical proofs — mutation-based analysis of LaTeX theorem statements",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bridge": "npx tsx src/bridge/lean-server.ts",
    "typecheck": "tsc --noEmit",
    "lint:tex": "npx tsx cli/lint.ts",
    "bench": "npx tsx bench/run.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "katex": "^0.16.33"
  }
}
