{
  "name": "theoremis",
  "version": "1.0.0",
  "type": "module",
  "description": "Formal verification services, accelerated by Lean 4 tooling. We help teams formalize critical guarantees and ship machine-checked results faster.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bridge": "npx tsx src/bridge/lean-server.ts",
    "typecheck": "tsc --noEmit",
    "lint:tex": "npx tsx cli/lint.ts",
    "bench": "npx tsx bench/run.ts",
    "perf": "npx tsx bench/perf.ts",
    "perf:ci": "npx tsx bench/perf.ts --ci",
    "size:check": "npx tsx bench/size-check.ts",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "katex": "^0.16.33"
  }
}